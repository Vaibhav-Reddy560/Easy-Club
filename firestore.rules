rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Standard owner-only access for clubs
    match /clubs/{clubId} {
      // Allow public read so the Join and JC Apply portals can fetch the club configuration
      allow read: if true;
      
      // Allow create if the user sets themselves as the owner
      allow create: if request.auth != null && 
        request.resource.data.ownerId == request.auth.uid;
      
      // Allow update if the user is the owner, OR if the API is appending members/applications
      allow update: if (request.auth != null && resource.data.ownerId == request.auth.uid) || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'memberEmails', 'jcApplications']);

      // Allow delete ONLY if the user is the owner
      allow delete: if request.auth != null && 
        resource.data.ownerId == request.auth.uid;

      // Same logic applies to subcollections (events, resources, etc.)
      match /{allSubcollections=**} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }
    }

    // Rules for saved explore clubs
    match /saved_explore_clubs/{docId} {
      allow read, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
    }


    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
